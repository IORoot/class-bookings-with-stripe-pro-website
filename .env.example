# ── Stripe mode (server) ─────────────────────────────────────────────────────
# test | live — flip on Netlify without redeploying the static site
STRIPE_MODE=live

# Test credentials (STRIPE_MODE=test)
STRIPE_SECRET_KEY_TEST=sk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...
STRIPE_PAYMENT_LINK_TEST=https://buy.stripe.com/test_...
STRIPE_RENEWAL_LINK_TEST=https://buy.stripe.com/test_...

# Live credentials (STRIPE_MODE=live)
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
STRIPE_PAYMENT_LINK_LIVE=https://buy.stripe.com/...
STRIPE_RENEWAL_LINK_LIVE=https://buy.stripe.com/...

# Legacy names (optional fallback when STRIPE_MODE=live)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Public (SvelteKit) ───────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://class-bookings-pro.netlify.app
PUBLIC_GITHUB_ISSUES_URL=https://github.com/IORoot/class-bookings-with-stripe-pro-website/issues
PUBLIC_GITHUB_DISCUSSIONS_URL=https://github.com/IORoot/class-bookings-with-stripe-pro-website/discussions
PUBLIC_WP_FREE_PLUGIN_URL=https://wordpress.org/plugins/class-bookings-with-stripe/

# Optional: direct Payment Links for `npm run dev` without `netlify dev`
# PUBLIC_STRIPE_MODE=test
# PUBLIC_STRIPE_PAYMENT_LINK_TEST=https://buy.stripe.com/test_...
# PUBLIC_STRIPE_RENEWAL_LINK_TEST=https://buy.stripe.com/test_...
# PUBLIC_STRIPE_PAYMENT_LINK_LIVE=https://buy.stripe.com/...
# PUBLIC_STRIPE_RENEWAL_LINK_LIVE=https://buy.stripe.com/...

# ── Netlify Functions (secrets — never commit) ───────────────────────────────
DOWNLOAD_TOKEN_SECRET=generate-a-long-random-string
GITHUB_TOKEN=github_pat_...read-only-on-private-plugin-repo
GITHUB_REPO=IORoot/class-bookings-with-stripe-pro
RESEND_API_KEY=re_...
EMAIL_FROM=Class Bookings Pro <pro@ioroot.com>
SITE_URL=https://class-bookings-pro.netlify.app
